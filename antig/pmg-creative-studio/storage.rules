rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow uploads to be stored and retrieved
    match /uploads/{clientSlug}/{allPaths=**} {
      allow read, write: if true; 
    }
    
    match /clients/{clientSlug}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
